{
  "title": "QUANTUM Phone Reveal",
  "description": "Reveals phone numbers from Israeli real estate listings using browser automation",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "listings": {
      "title": "Listings",
      "type": "array",
      "description": "Array of listings to process. Each must have: id, url, source.",
      "editor": "json",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "url": { "type": "string" },
          "source": { "type": "string", "enum": ["yad2", "yad1", "dira", "homeless", "banknadlan", "komo", "madlan"] },
          "sourceListingId": { "type": "string" },
          "address": { "type": "string" },
          "city": { "type": "string" }
        },
        "required": ["id", "url", "source"]
      }
    },
    "maxConcurrency": {
      "title": "Max Concurrency",
      "type": "integer",
      "description": "Maximum number of browser pages running in parallel",
      "default": 5,
      "minimum": 1,
      "maximum": 20
    },
    "proxyConfig": {
      "title": "Proxy Configuration",
      "type": "object",
      "description": "Apify proxy settings",
      "default": {
        "useApifyProxy": true,
        "apifyProxyGroups": ["RESIDENTIAL"],
        "countryCode": "IL"
      }
    }
  },
  "required": ["listings"]
}
